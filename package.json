{
  "name": "gestion-de-escuela",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:rules": "firebase emulators:exec --only firestore --project demo-test 'node test/firestore-rules.test.mjs'",
    "deploy:rules": "firebase deploy --only firestore --project evalua-facil-app",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build --output-dir storybook-static",
    "test:a11y": "bash ./scripts/run-a11y.sh",
    "test:responsive": "playwright test",
    "test:responsive:debug": "playwright test --debug",
    "test:responsive:headed": "playwright test --headed",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "design:verify": "npm run storybook:build && npm run test:a11y && npm run test:responsive"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fontsource-variable/outfit": "^5.2.8",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "dompurify": "^3.4.11",
    "exceljs": "^4.4.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-designs": "^11.1.4",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@storybook/test-runner": "^0.24.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "chromatic": "^18.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "postcss": "^8.5.15",
    "storybook": "^10.5.0",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
