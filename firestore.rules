rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // IMPORTANT: guard with exists() before get(). Students have NO users/{uid} doc, so a
    // bare get(users/{uid}).data.role throws during rule evaluation → the whole request is
    // denied with "Missing or insufficient permissions". exists() makes these return false
    // gracefully for any account without a users doc instead of erroring.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isDocente() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'docente';
    }

    // ── Ownership helpers (cross-document) ──────────────────────────────────
    // Students have NO docenteId of their own; ownership is indirect via the
    // subject the enrollment belongs to. Guard every get() with exists() so a
    // dangling reference denies gracefully instead of erroring the whole request.

    // True when the signed-in user owns the subject `asigId` (is its docente).
    function ownsSubject(asigId) {
      return exists(/databases/$(database)/documents/subjects/$(asigId)) &&
        get(/databases/$(database)/documents/subjects/$(asigId)).data.docenteId == request.auth.uid;
    }

    // True when the signed-in user owns the activity `actId` (is its docente).
    function ownsActivity(actId) {
      return exists(/databases/$(database)/documents/activities/$(actId)) &&
        get(/databases/$(database)/documents/activities/$(actId)).data.docenteId == request.auth.uid;
    }

    // True when the signed-in student owns the enrollment doc `studentId`
    // (their auth uid is stamped on it — set during activation).
    function ownsStudentDoc(studentId) {
      return exists(/databases/$(database)/documents/students/$(studentId)) &&
        get(/databases/$(database)/documents/students/$(studentId)).data.uid == request.auth.uid;
    }

    match /schools/{schoolId} {
      allow read: if request.auth != null;
      // Schools are created/edited only from teacher flows (Register/Onboarding
      // run AFTER the users/{uid} doc exists, Profile is teacher-only), so
      // student accounts never need write access here.
      allow create: if isAdmin() || isDocente();
      allow update: if isAdmin() || isDocente();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId &&
        request.resource.data.role == 'docente';
      allow update: if isAdmin() ||
        (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      // Public read stays: the QR/code activation flow looks up students before
      // the account exists.
      allow read: if true;

      // Only the owning teacher (docente of the target subject) creates/deletes
      // enrollments. Students never create or delete their own record.
      allow create: if isDocente() && ownsSubject(request.resource.data.asignaturaId);
      allow delete: if isDocente() && ownsSubject(resource.data.asignaturaId);

      // Two legitimate updaters:
      //  (a) the owning teacher — may edit any field of their students.
      //  (b) the student themselves, during activation — claims an un-owned
      //      record by stamping their uid, and may only touch their own record
      //      afterwards. Identity fields (username/escuela/subject) are frozen
      //      so a student can't move or rename an enrollment, and can't hijack a
      //      record already claimed by a different uid.
      allow update: if
        (isDocente() && ownsSubject(resource.data.asignaturaId)) ||
        (
          request.auth != null &&
          request.resource.data.uid == request.auth.uid &&
          (resource.data.uid == null || resource.data.uid == request.auth.uid) &&
          request.resource.data.username == resource.data.username &&
          request.resource.data.escuelaId == resource.data.escuelaId &&
          request.resource.data.asignaturaId == resource.data.asignaturaId
        );
    }

    match /subjects/{subjectId} {
      allow read: if true;
      // Only teachers create subjects, always attributed to themselves.
      allow create: if isDocente() &&
        request.auth.uid == request.resource.data.docenteId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
    }

    match /activities/{activityId} {
      allow read: if request.auth != null;
      // Create only within a subject you own, attributed to yourself.
      allow create: if isDocente() &&
        request.auth.uid == request.resource.data.docenteId &&
        ownsSubject(request.resource.data.asignaturaId);
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;

      // Evaluación questions — only the owning teacher (looked up on the
      // parent activity) may write; any authenticated user may read. The
      // student-facing UI is responsible for not requesting `respuestaCorrecta`
      // while an attempt is in progress (rules can't filter fields).
      match /preguntas/{preguntaId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/activities/$(activityId)).data.docenteId;
      }
    }

    // Personal question bank (Evaluaciones) — strictly owner-only.
    match /bancoReactivos/{reactivoId} {
      allow read, update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.docenteId;
    }

    // Personal rubric bank (Entregables) — strictly owner-only. Students never
    // read this collection: the activity stores its own COPY of the rubric.
    match /bancoRubricas/{rubricaId} {
      allow read, update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.docenteId;
    }

    // Permanent course materials (syllabus, guides, etc.) — not tied to an
    // activity, so they never generate a submission or grade. Same
    // read/write shape as activities: any authenticated user (teacher or
    // enrolled student) can read; only the owning teacher can write/delete.
    match /resources/{resourceId} {
      allow read: if request.auth != null;
      // Only teachers create resources, always attributed to themselves.
      allow create: if isDocente() &&
        request.auth.uid == request.resource.data.docenteId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
    }

    // "Material de apoyo" — per-parcial course material (one or more files +
    // optional rich-text description). Independent of `activities`: it never
    // creates a submission/grade, so it has no link to `submissions` at all.
    // Same read/write shape as resources/activities.
    match /materials/{materialId} {
      allow read: if request.auth != null;
      // Only teachers create materials, always attributed to themselves.
      allow create: if isDocente() &&
        request.auth.uid == request.resource.data.docenteId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
    }

    match /submissions/{submissionId} {
      allow read: if request.auth != null;

      // A submission is written either by the student who owns it (submit /
      // resubmit / evaluación autosave) or by the teacher who owns the activity
      // (grading, marking complete). `alumnoId` is the STUDENT ENROLLMENT DOC ID
      // (not the auth uid), so ownership resolves through ownsStudentDoc().
      // NOTE: this restores per-student / per-teacher isolation (a student can no
      // longer touch another student's submission). It does NOT yet stop a student
      // from writing their OWN `calificacion` — auto-graded evaluaciones compute
      // the grade client-side, so closing that requires moving grading server-side
      // (tracked as a follow-up).
      allow create: if request.auth != null && (
        ownsStudentDoc(request.resource.data.alumnoId) ||
        ownsActivity(request.resource.data.actividadId)
      );
      allow update: if request.auth != null && (
        ownsStudentDoc(resource.data.alumnoId) ||
        ownsActivity(resource.data.actividadId)
      );
      allow delete: if request.auth != null && (
        ownsStudentDoc(resource.data.alumnoId) ||
        ownsActivity(resource.data.actividadId)
      );

      // Evaluación answers (autosave + teacher revision). Only the student who
      // owns the parent submission, or the teacher who owns the parent activity,
      // may READ or WRITE — closes the cross-student hole where any
      // authenticated account could see or edit anyone's answers. Reads are
      // always scoped to a concrete submissionId (single doc or subcollection
      // query under it), so the parent get() resolves for list queries too.
      match /respuestas/{preguntaId} {
        allow read, write: if request.auth != null && (
          (
            exists(/databases/$(database)/documents/submissions/$(submissionId)) &&
            ownsStudentDoc(get(/databases/$(database)/documents/submissions/$(submissionId)).data.alumnoId)
          ) || (
            exists(/databases/$(database)/documents/submissions/$(submissionId)) &&
            ownsActivity(get(/databases/$(database)/documents/submissions/$(submissionId)).data.actividadId)
          )
        );
      }
    }

    match /plans/{planId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if request.auth != null && (
        isAdmin() || resource.data.docenteId == request.auth.uid
      );
      allow create: if isAdmin() || (
        isDocente() &&
        request.resource.data.docenteId == request.auth.uid &&
        request.resource.data.status in ['pendiente_pago', 'trial']
      );
      allow update: if isAdmin() || (
        isDocente() &&
        resource.data.docenteId == request.auth.uid &&
        request.resource.data.docenteId == resource.data.docenteId &&
        request.resource.data.status == 'pendiente_pago'
      );
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null && (
        isAdmin() || resource.data.docenteId == request.auth.uid
      );
      allow create: if isAdmin() || (
        isDocente() &&
        request.resource.data.docenteId == request.auth.uid &&
        request.resource.data.status == 'pendiente'
      );
      allow update, delete: if isAdmin();
    }

    // Public payment configuration (display data only: public keys, bank info).
    // Secrets (access tokens / client secrets) live in server env vars, never here.
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Personal calendar events created by the teacher.
    match /events/{eventId} {
      allow read, update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.docenteId;
    }

    // Teacher's class schedule blocks (Mi Horario — legacy recurring blocks).
    match /horario/{bloqueId} {
      allow read, update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.docenteId;
    }

    // Programación de bloques de clases por asignatura (fechas reales generadas
    // a partir de un rango + patrones semanales; se pueden mover/editar/eliminar
    // individualmente).
    match /horarioBloques/{bloqueId} {
      allow read, update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.docenteId;
    }

    // Días de asueto del docente. Cada doc marca una fecha en la que no se
    // permiten (según su alcance) clases, eventos y/o actividades.
    match /asuetos/{asuetoId} {
      allow read, update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.docenteId;
    }

    // Vacaciones del docente. Cada doc marca un PERIODO (fechaInicio–fechaFin)
    // en el que no se permiten (según su alcance) clases, eventos y/o
    // actividades — misma estructura que asuetos, pero para un rango de días.
    match /vacaciones/{vacacionId} {
      allow read, update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.docenteId;
    }
  }
}
