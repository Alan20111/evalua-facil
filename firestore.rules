rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isDocente() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'docente';
    }

    match /schools/{schoolId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId &&
        request.resource.data.role == 'docente';
      allow update: if isAdmin() ||
        (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
    }

    match /activities/{activityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
    }

    // Permanent course materials (syllabus, guides, etc.) — not tied to an
    // activity, so they never generate a submission or grade. Same
    // read/write shape as activities: any authenticated user (teacher or
    // enrolled student) can read; only the owning teacher can write/delete.
    match /resources/{resourceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.docenteId;
    }

    match /submissions/{submissionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      // Only the owning teacher (of the activity) or the student who made the
      // submission may delete it.
      allow delete: if request.auth != null && (
        request.auth.uid == get(/databases/$(database)/documents/activities/$(resource.data.actividadId)).data.docenteId
        || resource.data.alumnoId == request.auth.uid
      );
    }

    match /plans/{planId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if request.auth != null && (
        isAdmin() || resource.data.docenteId == request.auth.uid
      );
      allow create: if isAdmin() || (
        isDocente() &&
        request.resource.data.docenteId == request.auth.uid &&
        request.resource.data.status in ['pendiente_pago', 'trial']
      );
      allow update: if isAdmin() || (
        isDocente() &&
        resource.data.docenteId == request.auth.uid &&
        request.resource.data.docenteId == resource.data.docenteId &&
        request.resource.data.status == 'pendiente_pago'
      );
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null && (
        isAdmin() || resource.data.docenteId == request.auth.uid
      );
      allow create: if isAdmin() || (
        isDocente() &&
        request.resource.data.docenteId == request.auth.uid &&
        request.resource.data.status == 'pendiente'
      );
      allow update, delete: if isAdmin();
    }

    // Public payment configuration (display data only: public keys, bank info).
    // Secrets (access tokens / client secrets) live in server env vars, never here.
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
