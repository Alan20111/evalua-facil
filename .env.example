# Copia este archivo a ".env" y rellena los valores (o cárgalos en Vercel → Settings → Environment Variables).
# Son claves PÚBLICAS del cliente web (Firebase las protege con reglas de Firestore + dominios autorizados).

# Firebase (Console → Project settings → Your apps → SDK setup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary (subida de archivos de alumnos, preset unsigned)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Design System & Testing (Storybook, Chromatic, Figma)
# Chromatic (visual testing premium)
CHROMATIC_PROJECT_TOKEN=

# Vercel (deploy Storybook)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Figma Tokens (sincronización de tokens)
FIGMA_FILE_ID=
FIGMA_PERSONAL_TOKEN=
